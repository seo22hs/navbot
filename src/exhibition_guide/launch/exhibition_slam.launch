<launch>
  <arg name="paused" default="false" />
  <arg name="use_sim_time" default="true" />
  <arg name="gui" default="true" />
  <arg name="headless" default="false" />
  <arg name="debug" default="false" />
  <arg name="model" default="$(optenv TURTLEBOT3_MODEL burger)" />
  <arg name="x_pos" default="0.0" />
  <arg name="y_pos" default="-6.0" />
  <arg name="z_pos" default="0.05" />
  <arg name="yaw" default="1.57" />
  <arg name="open_rviz" default="true" />

  <include file="$(find exhibition_guide)/launch/exhibition_world_with_robot.launch">
    <arg name="paused" value="$(arg paused)" />
    <arg name="use_sim_time" value="$(arg use_sim_time)" />
    <arg name="gui" value="$(arg gui)" />
    <arg name="headless" value="$(arg headless)" />
    <arg name="debug" value="$(arg debug)" />
    <arg name="model" value="$(arg model)" />
    <arg name="x_pos" value="$(arg x_pos)" />
    <arg name="y_pos" value="$(arg y_pos)" />
    <arg name="z_pos" value="$(arg z_pos)" />
    <arg name="yaw" value="$(arg yaw)" />
  </include>

  <include file="$(find exhibition_guide)/launch/exhibition_gmapping.launch">
    <arg name="set_base_frame" value="base_footprint" />
    <arg name="set_odom_frame" value="odom" />
    <arg name="set_map_frame" value="map" />
  </include>

  <group if="$(arg open_rviz)">
    <node
      pkg="rviz"
      type="rviz"
      name="rviz"
      output="screen"
      args="-d $(find turtlebot3_slam)/rviz/turtlebot3_gmapping.rviz" />
  </group>
</launch>
